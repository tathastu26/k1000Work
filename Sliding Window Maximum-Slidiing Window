//Sliding Window Maximum-Slidiing Window
class Solution {
public:
    vector<int> maxSlidingWindow(vector<int>& nums, int k) {
        int maxone=INT_MIN;
        vector<int>ans;
        for(int right=0;right<k;right++)
        {
            maxone=max(maxone,nums[right]);
        }
        ans.push_back(maxone);
        int left=0;
        for(int right=1;right<=nums.size()-k;right++)
        {
            if(maxone!=nums[right-1])
            {
                maxone=max(maxone,nums[right+k-1]);
            }
            else
            {
                maxone=INT_MIN;
                for(int j=right;j<right+k;j++)
                {
                    maxone=max(maxone,nums[j]);
                }
            }
            ans.push_back(maxone);
        }
        return ans;
    }
};
